@model UniDesc.Web.Models.Ticket

<h2>Utwórz Nowe Zgłoszenie</h2>

<div asp-validation-summary="All"></div>

<form asp-action="Create" method="post">

    <div>
        <label asp-for="Title">Tytuł</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>

    <div>
        <label asp-for="Description">Opis</label>
        <input asp-for="Description" />
        <span asp-validation-for="Description"></span>
    </div>

    <div>
        <label asp-for="Status">Status</label>
        <select asp-for="Status">
            <option value="New">Nowe</option>
            <option value="InProgress">W trakcie</option>
            <option value="Closed">Zamknięte</option>
        </select>
        <span asp-validation-for="Status"></span>
    </div>

    <button type="submit">Utwórz zgłoszenie</button>
</form>