@model IEnumerable<UniDesc.Web.Models.Ticket>
    @using UniDesc.Web.Models

    <h2>Lista Zgłoszeń</h2>

    <p>
        <a asp-action="Create">Dodaj nowe zgłoszenie</a>
    </p>

    <form method="get">
        <input type="text" name="status" placeholder="Filtruj po statusie..." value="@Context.Request.Query["status"]" />
        <input type="text" name="search" placeholder="Szukaj po tytule..." value="@Context.Request.Query["search"]" />
        <button type="submit">Szukaj</button>
    </form>

    <table>
        <thead>
            <tr>
                <th>
                    <a asp-action="Index" asp-route-sortBy="Title">Tytuł</a>
                </th>
                <th>Opis</th>
                <th>
                    <a asp-action="Index" asp-route-sortBy="Status">Status</a>
                </th>
                <th>
                    <a asp-action="Index" asp-route-sortBy="CreatedAt">Data Utworzenia</a>
                </th>
                <th>Akcje</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var ticket in Model)
        {
            <tr>
                <td>@ticket.Title</td>
                <td>@ticket.Description</td>

                <td>
                    @{
                        switch (ticket.Status)
                        {
                            case TicketStatus.New:
                        <span style="color:blue">New</span>;
                                break;

                            case TicketStatus.InProgress:
                        <span style="color:orange">InProgress</span>;
                                break;

                            case TicketStatus.Closed:
                        <span style="color:green">Closed</span>;
                                break;
                        }
                    }
                </td>

                <td>@ticket.CreatedDate</td>

                <td>
                    <a asp-action="Details" asp-route-id="@ticket.Id">Szczegóły</a>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="pagination">
        @{
        int currentPage;
        int.TryParse(Context.Request.Query["page"], out currentPage);
        if (currentPage == 0) currentPage = 1;
        }

        @if (currentPage > 1)
    {
        <a asp-action="Index" asp-route-page="@(currentPage - 1)" class="page-link">Previous</a>
    }

        @for (var i = 1; i <= (Model.Count() / 10) + 1; i++)
    {
        <a asp-action="Index" asp-route-page="@i" class="page-link">@i</a>
    }

        @if (currentPage < (Model.Count() / 10) + 1)
    {
        <a asp-action="Index" asp-route-page="@(currentPage + 1)" class="page-link">Next</a>
    }
    </div>
